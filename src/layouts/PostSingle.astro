---
import BlogCard from "@/components/BlogCard.astro";
import config from "@/config/config.json";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import similarItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { FaRegClock, FaRegFolder, FaRegUserCircle } from "react-icons/fa";
import ImageMod from "./components/ImageMod.astro";
import { render } from "astro:content";

const COLLECTION_FOLDER = "blog";
const { post } = Astro.props;
const { preview_items } = config.settings;

const posts = await getSinglePage(COLLECTION_FOLDER);
const products = await getSinglePage("products");
const similarPosts = similarItems(post, posts)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, preview_items);
const { Content } = await render(post);
const { title, author, categories, image, date, tags } = post.data;

const normalizedPostTags = new Set(
  tags.map((tag: string) => tag.toLowerCase().trim()),
);
const relatedProducts = products
  .filter((product) =>
    product.data.tags.some((tag: string) =>
      normalizedPostTags.has(tag.toLowerCase().trim()),
    ),
  )
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"))
  .slice(0, preview_items);
---

<section class="section pt-7">
  <div class="container">
    <div class="row justify-center">
      <article class="lg:col-10">
        {
          image && (
            <div class="mb-10">
              <ImageMod
                src={image}
                height={500}
                width={1200}
                alt={title}
                class="w-full rounded"
                format="webp"
              />
            </div>
          )
        }
        <h1 set:html={markdownify(title)} class="h2 mb-4" />
        <ul class="mb-4">
          <li class="mr-4 inline-block">
            <a href={`/authors/${slugify(author)}/`}>
              <FaRegUserCircle className={"mr-2 -mt-1 inline-block"} />
              {humanize(author)}
            </a>
          </li>
          <li class="mr-4 inline-block">
            <FaRegFolder className={"mr-2 -mt-1 inline-block"} />
            {
              categories.map((category: string, index: number) => (
                <a href={`/categories/${slugify(category)}/`}>
                  {humanize(category)}
                  {index !== categories.length - 1 && ","}
                </a>
              ))
            }
          </li>
          <li class="mr-4 inline-block">
            <FaRegClock className={"mr-2 -mt-1 inline-block"} />
            {dateFormat(date)}
          </li>
        </ul>
        <div class="content mb-24">
          <Content />
        </div>
        <div class="row items-start justify-between">
          <div class="mb-10 flex items-center lg:col-8 lg:mb-0">
            <h5 class="mr-3">Stichworte:</h5>
            <ul>
              {
                tags.map((tag: string) => (
                  <li class="inline-block">
                    <a
                      class="m-1 block rounded bg-light px-3 py-1 hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-dark"
                      href={`/tags/${slugify(tag)}/`}
                    >
                      {humanize(tag)}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <!--div class="flex items-center lg:col-4">
            <h5 class="mr-3">Teilen:</h5>
            <Share
              className="social-icons"
              title={title}
              description={description}
              slug={post.id}
            />
          </div-->
        </div>
      </article>
      <div class="mt-10 lg:col-3 flex justify-center">
        <a href="/blog/" class="btn btn-outline-primary">Zurück zum Blog</a>
      </div>
    </div>

    <!-- Related posts -->
    {
      similarPosts.length > 0 && (
        <div class="section pb-0">
          <h2 class="h3 mb-12 text-center">Ähnliche Blogartikel</h2>
          <div class="row justify-center">
            {similarPosts.map((post) => (
              <div class="lg:col-4 md:col-6 mb-14">
                <BlogCard data={post} />
              </div>
            ))}
          </div>
        </div>
      )
    }

    {
      relatedProducts.length > 0 && (
        <div class="section pb-0">
          <h2 class="h3 mb-12 text-center">Passende Produkte</h2>
          <div class="row justify-center">
            {relatedProducts.map((product) => (
              <div class="mb-6 col-12 lg:col-4">
                <a
                  class="block h-full rounded-2xl border border-border bg-white p-6 transition-colors hover:border-[#00CE7E] dark:border-darkmode-border dark:bg-darkmode-body"
                  href={`/products/${product.id}/`}
                >
                  <p class="mb-2 font-secondary text-sm font-semibold uppercase tracking-[0.12em] text-[#00A869]">
                    Produkt
                  </p>
                  <h3 class="mb-3 font-primary text-h5 font-bold leading-tight hyphens-auto wrap-break-word text-text-dark dark:text-darkmode-text-dark">
                    {product.data.title}
                  </h3>
                  <p class="font-secondary text-base text-text dark:text-darkmode-text-light">
                    {product.data.description}
                  </p>
                </a>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
