---
import HomepageLeadHeading from "@/partials/HomepageLeadHeading.astro";
---

<>
  <HomepageLeadHeading
    eyebrow="Alpine Data Ventures Datenberatung"
    title="Aus unklaren Daten werden realistische nächste Schritte"
  />
  <section class="section pt-2 pb-12 md:pb-16">
    <div class="container">
      <div class="row items-stretch gap-y-10">
        <div class="col-12 md:col-6">
          <div class="flex h-full flex-col justify-center text-left">
            <p
              class="font-secondary text-lg font-normal text-text dark:text-darkmode-text"
            >
              ADV hilft mittelständischen Unternehmen ihre Datenlandschaft zu
              verstehen, sinnvolle KI- und Dateninitiativen zu priorisieren und
              erste Ergebnisse schnell in die Umsetzung zu bringen.
            </p>

            <div class="mt-24 flex flex-wrap items-center gap-4">
              <a
                href="#typische-ausgangssituation"
                class="inline-flex items-center justify-center rounded-md bg-[#00CE7E] px-6 py-3 font-secondary text-base font-bold text-white transition-opacity hover:opacity-90"
              >
                Typische Ausgangssituation
              </a>
              <a
                href="https://calendly.com/andreas-klostermann-alpinedata/ersttermin"
                class="btn btn-primary inline-flex items-center"
              >
                Gespräch starten
                <span class="ml-2" aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <p
              class="mt-3 font-secondary text-base font-normal text-text dark:text-darkmode-text"
            >
              Senior Expertise · Fixpreis · Quick Wins statt Großprojekt
            </p>
          </div>
        </div>

        <div class="col-12 md:col-6">
          <figure
            class="hero-image-compare"
            data-hero-compare
            style="--split: 50%;"
          >
            <img
              src="/images/heropath.jpg"
              alt="ADV Hero"
              class="hero-image-compare__image"
              loading="lazy"
            />

            <div class="hero-image-compare__overlay" aria-hidden="true">
              <img
                src="/images/heropath_pixel.jpg"
                alt=""
                class="hero-image-compare__image"
                loading="lazy"
              />
            </div>

            <div class="hero-image-compare__divider" aria-hidden="true"></div>

            <input
              class="hero-image-compare__range"
              type="range"
              min="0"
              max="100"
              value="50"
              aria-label="Bereich zwischen klarem und verpixeltem Bild verschieben"
            />
          </figure>
        </div>
      </div>
    </div>
  </section>
</>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-hero-compare]").forEach((root) => {
      const range = root.querySelector(".hero-image-compare__range");
      if (!range || root.dataset.initialized === "true") return;

      const setSplit = (value) => {
        root.style.setProperty("--split", `${value}%`);
      };

      setSplit(range.value);
      range.addEventListener("input", (event) => {
        setSplit(event.target.value);
      });

      root.dataset.initialized = "true";
    });
  });
</script>
