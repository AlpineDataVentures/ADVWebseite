---
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";
const { whyAdv } = Astro.props;
---

{
  whyAdv.data.enable && (
    <section class="section py-8 pb-20">
      <div class="container">
        <div class="row items-start gap-y-10">
          <div class="col-12 md:col-6 md:pr-10">
            <h2 class="font-primary font-bold text-black dark:text-white">
              <span set:html={markdownify(whyAdv.data.left_intro)} />{" "}
              <span
                class="adv-contact-gradient"
                set:html={markdownify(whyAdv.data.left_highlight)}
              />{" "}
              <span set:html={markdownify(whyAdv.data.left_outro)} />
            </h2>
          </div>

          <div class="col-12 md:col-6 md:pl-10">
            <h3
              class="mb-6 font-primary text-h3 font-bold text-black dark:text-white"
              set:html={markdownify(whyAdv.data.right_title)}
            />
            <div class="space-y-6">
              {whyAdv.data.items.map(
                (item: { caption: string; text: string }) => (
                  <article>
                    <h4
                      class="font-primary text-h6 font-bold text-text-dark dark:text-darkmode-text-dark"
                      set:html={markdownify(item.caption)}
                    />
                    <p
                      class="font-secondary text-base font-normal text-text dark:text-darkmode-text-light"
                      set:html={markdownify(item.text)}
                    />
                  </article>
                ),
              )}
            </div>
          </div>
        </div>

        <div class="mt-10">
          <ImageMod
            src={whyAdv.data.image}
            alt="Warum Alpine Data Ventures Team"
            height={900}
            width={1600}
            class="h-64 w-full object-cover object-center md:h-120"
            format="webp"
          />
        </div>
      </div>
    </section>
  )
}
