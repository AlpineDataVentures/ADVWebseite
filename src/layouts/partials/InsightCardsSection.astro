---
import DynamicIcon from "@/helpers/DynamicIcon";

interface InsightCard {
  icon: string;
  titleStart?: string;
  titleHighlight: string;
  titleEnd?: string;
  text: string;
  link: string;
}

interface Props {
  titleStart?: string;
  titleHighlight: string;
  titleEnd?: string;
  cards: InsightCard[];
}

const { titleStart, titleHighlight, titleEnd, cards } = Astro.props as Props;

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

const buildHighlightedTitle = (
  start: string | undefined,
  highlight: string,
  end: string | undefined,
) =>
  `${escapeHtml(start ?? "")}<span class="adv-contact-gradient">${escapeHtml(highlight)}</span>${escapeHtml(end ?? "")}`;
---

<section class="section pt-10 md:pt-12">
  <div class="container">
    <h2
      class="mb-8 w-full lg:w-2/3 text-left font-primary text-h2-sm font-bold text-text-dark dark:text-darkmode-text-dark md:text-h2"
      set:html={buildHighlightedTitle(titleStart, titleHighlight, titleEnd)}
    />

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-4">
      {
        cards.map((item) => (
          <a
            href={item.link}
            class="insight-card h-full min-h-88 rounded-lg border border-black p-6 text-center transition-all duration-200 hover:-translate-y-1 hover:shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 dark:border-white md:p-7"
          >
            <div class="flex items-center justify-center text-text-dark dark:text-darkmode-text-dark">
              <DynamicIcon icon={item.icon} className="h-14 w-14" />
            </div>
            <h4
              class="font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark"
              set:html={buildHighlightedTitle(
                item.titleStart,
                item.titleHighlight,
                item.titleEnd,
              )}
            />
            <div class="flex items-center justify-center">
              <p class="font-secondary text-base font-normal text-text dark:text-darkmode-text-light">
                {item.text}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .insight-card {
    display: grid;
    grid-template-rows: 1fr auto 1fr;
  }
</style>
