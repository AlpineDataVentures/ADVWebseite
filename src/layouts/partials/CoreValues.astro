---
import DynamicIcon from "@/helpers/DynamicIcon";

export interface CoreValue {
  title: string;
  icon: string;
  description: string;
}

interface Props {
  core_values: CoreValue[];
  sectionClassName?: string;
}

const { core_values, sectionClassName = "mb-16" } = Astro.props as Props;
---

<section class={sectionClassName}>
  <div class="container">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        Array.isArray(core_values) &&
          core_values.map((value) => (
            <article class="group flex h-full flex-col rounded-2xl border border-black/80 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-[#00CE7E] hover:shadow-[0_14px_30px_rgba(0,0,0,0.08)] dark:border-white/70 dark:bg-darkmode-body">
              <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#00CE7E]/10 text-[#00CE7E] transition-colors duration-300 group-hover:bg-[#00CE7E] group-hover:text-white">
                <DynamicIcon className="h-6 w-6" icon={value.icon} />
              </div>
              <h3 class="mb-3 font-primary text-h4 font-bold text-text-dark dark:text-darkmode-text-dark">
                {value.title}
              </h3>
              <p class="font-secondary text-base font-normal leading-relaxed text-text dark:text-darkmode-text-light">
                {value.description}
              </p>
            </article>
          ))
      }
    </div>
  </div>
</section>
