---
import { markdownify } from "@/lib/utils/textConverter";
import ImageMod from "@/components/ImageMod.astro";
const { testimonial } = Astro.props;
const hasMultipleTestimonials = testimonial.data.testimonials.length > 2;
---

{testimonial.data.enable && (
  <section class="section testimonial-section pb-20 pt-0">
    <div class="container pt-0">
      <div class="row">
        <div class="col-12 relative testimonial-slider-wrapper">
          <div class="relative testimonial-slider-container">
            <!-- Swiper -->
            <div
              class={`swiper testimonial-slider ml-0! mr-auto! ${hasMultipleTestimonials ? "w-[90%]" : "w-full lg:w-1/2"}`}
            >
              <div class="swiper-wrapper">
                {testimonial.data.testimonials.map(
                  (item: {
                    avatar: string;
                    content: string;
                    name: string;
                    designation: string;
                    link: string;
                  }, index: number) => (
                    <div class="swiper-slide">
                      <div class="testimonial-card rounded-lg bg-light px-7 py-4 dark:bg-darkmode-light">
                      <div>
                        <svg
                          width="94"
                          height="70"
                          viewBox="0 0 88 64"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <defs>
                            <linearGradient
                              id={`quote-gradient-${index}`}
                              x1="0"
                              y1="0"
                              x2="1"
                              y2="1"
                            >
                              <stop offset="0%" stop-color="#04D17A" />
                              <stop offset="100%" stop-color="#03B57D" />
                            </linearGradient>
                          </defs>
                          <text
                            x="0"
                            y="130"
                            fill={`url(#quote-gradient-${index})`}
                            font-family="var(--font-primary)"
                            font-size="164"
                            font-weight="700"
                            letter-spacing="0"
                          >
                            “
                          </text>
                        </svg>
                      </div>
                        <blockquote
                          class="mt-4 text-justify font-primary text-h7 font-bold"
                          set:html={markdownify(item.content)}
                        />
                        <div class="flex items-center justify-between gap-6">
                          <div class="font-secondary text-[1.125rem] font-normal">
                            <span>{item.name}</span>
                            <span class="mx-2">-</span>
                            <span>{item.designation}</span>
                          </div>
                          <div class="text-dark dark:text-white shrink-0">
                            <ImageMod
                              height={100}
                              width={170}
                              class="object-contain"
                              src={item.avatar}
                              alt={item.name}
                              format="webp"
                            />
                          </div>
                        </div>
                        <div class="mb-4 mt-1 flex justify-start">
                          <a
                            class="btn-testimonial-invert btn-sm"
                            href={item.link}
                          >
                            Kundenstimmen
                            <span class="ml-2" aria-hidden="true">&rarr;</span>
                          </a>
                        </div>
                      </div>
                    </div>
                  ),
                )}
              </div>
            </div>

            {hasMultipleTestimonials && (
              <>
                <!-- Navigation Buttons -->
                <div class="swiper-button-prev testimonial-button-prev"></div>
                <div class="swiper-button-next testimonial-button-next"></div>
              </>
            )}
          </div>

          {hasMultipleTestimonials && (
            <div class="testimonial-slider-pagination mt-8 flex items-center justify-center text-center"></div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<script>
  import { Swiper } from "swiper";
  import "swiper/css";
  import "swiper/css/pagination";
  import "swiper/css/navigation";
  import { Autoplay, Navigation, Pagination } from "swiper/modules";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".testimonial-slider-wrapper").forEach((wrapper) => {
      const sliderEl = wrapper.querySelector(".testimonial-slider");
      const slideCount = wrapper.querySelectorAll(".swiper-slide").length;

      if (!(sliderEl instanceof HTMLElement) || slideCount <= 1) return;

      const paginationEl = wrapper.querySelector(".testimonial-slider-pagination");
      const prevEl = wrapper.querySelector(".testimonial-button-prev");
      const nextEl = wrapper.querySelector(".testimonial-button-next");

      if (
        !(paginationEl instanceof HTMLElement) ||
        !(prevEl instanceof HTMLElement) ||
        !(nextEl instanceof HTMLElement)
      )
        return;

      const sliderElement = sliderEl as HTMLElement;
      const paginationElement = paginationEl as HTMLElement;
      const prevElement = prevEl as HTMLElement;
      const nextElement = nextEl as HTMLElement;

      new Swiper(sliderElement, {
        modules: [Pagination, Autoplay, Navigation],
        spaceBetween: 24,
        loop: true,
        centeredSlides: false,
        autoplay: {
          delay: 2500,
          disableOnInteraction: false,
        },
        pagination: {
          el: paginationElement,
          type: "bullets",
          clickable: true,
        },
        navigation: {
          nextEl: nextElement,
          prevEl: prevElement,
        },
        breakpoints: {
          0: { slidesPerView: 1 },
          768: { slidesPerView: 2 },
          1200: { slidesPerView: 2 },
        },
      });
    });
  });
</script>
