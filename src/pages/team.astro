---
import Base from "@/layouts/Base.astro";
import HomepageLeadHeading from "@/partials/HomepageLeadHeading.astro";
import TextLeftImageRightSection from "@/partials/TextLeftImageRightSection.astro";
import ContactSpotlightSection from "@/partials/ContactSpotlightSection.astro";
import { getEntry, type CollectionEntry } from "astro:content";
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getSinglePage } from "@/lib/contentParser.astro";
import { FaCheck } from "react-icons/fa";
import Social from "@/components/Social.astro";

const team = (await getEntry("team", "-index")) as CollectionEntry<"team">;
const COLLECTION_FOLDER = "authors";
const authors = await getSinglePage(COLLECTION_FOLDER);

// Hilfsfunktion: Nachname extrahieren (letztes Wort im Titel)
function getLastName(fullName: string) {
  const parts = fullName.trim().split(" ");
  return parts[parts.length - 1];
}

// Sortierung nach Nachname (alphabetisch)
const sortedAuthors = authors.sort((a, b) =>
  getLastName(a.data.title).localeCompare(getLastName(b.data.title)),
);

const { title, meta_title, description, image, eyebrow } = team.data;
const teamBodyHtml = await markdownify(team.body ?? "");
const ctaDescriptionText = team.data.callToAction.description
  .replace(/<br\s*\/?>/g, "\n")
  .replace(/\n{2,}/g, "\n\n")
  .trim();
---

<Base
  title={title}
  meta_title={meta_title}
  image={image}
  description={description}
>
  <HomepageLeadHeading eyebrow={eyebrow} title={title} />

  <TextLeftImageRightSection
    textHtml={teamBodyHtml}
    imageSrc={image}
    imageAlt="Das Team"
    imageWidth={2048}
    imageHeight={1152}
  />
  <!-- Profile from authors -->
  {
    sortedAuthors.map((author, index: number) => (
      <section class={`section-sm ${index % 2 === 0 && "bg-gradient"}`}>
        <div class="container">
          <div class="row items-center justify-between">
            <div
              class={`mb:md-0 mb-6 md:col-5 ${index % 2 !== 0 && "md:order-2"}`}
            >
              <ImageMod
                src={author.data.image ? author.data.image : ""}
                height={480}
                width={520}
                alt={author.data.title}
                format="webp"
              />
            </div>
            <div class={`md:col-7 lg:col-6 ${index % 2 !== 0 && "md:order-1"}`}>
              <h2
                set:html={markdownify(author.data.title)}
                class="mb-4 font-primary"
              />
              <p
                set:html={markdownify(author.body ?? "")}
                class="mb-8 font-secondary text-base"
              />
              <ul>
                {author.data.bullet_points.map((bullet: string) => (
                  <li class="relative mb-4 pl-6">
                    <FaCheck className={"absolute left-0 top-1.5"} />
                    <span
                      set:html={markdownify(bullet)}
                      class="font-secondary"
                    />
                  </li>
                ))}
              </ul>
              <div class="mt-8 flex items-center lg:col-6">
                <h5 class="mr-3">Kontakt:</h5>
                <Social source={author.data.social} className="social-icons" />
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }
  <ContactSpotlightSection
    titleStart="Werde Teil"
    titleHighlight="unseres Teams"
    leadText={ctaDescriptionText}
    buttonHref={team.data.callToAction.button.link}
    buttonLabel={team.data.callToAction.button.label}
    imageSrc={team.data.callToAction.image}
    imageAlt={team.data.callToAction.title}
    avatarBeforeText={true}
  />
</Base>
