---

<Base
  title="Forschungsprojekte"
  meta_title="Forschungsprojekte"
  description="Forschungs- und Innovationsprojekte im Bereich Daten, Analytics und künstliche Intelligenz."
>
  <HomepageLeadHeading
    eyebrow="Forschungsprojekte"
    title="Forschungs- und Innovationsprojekte im Bereich Daten, Analytics und Künstliche Intelligenz"
  />

  <TextLeftImageRightSection
    text="Technologische Innovation entsteht selten isoliert. Gerade in den Bereichen Data & Analytics, künstliche Intelligenz, Datenplattformen, Automatisierung, industrielle Digitalisierung und intelligente Informationssysteme werden neue Lösungen zunehmend in Kooperation zwischen Unternehmen, Forschungseinrichtungen und Technologiepartnern entwickelt. Deshalb engagieren wir uns aktiv als Partner in Forschungs- und Innovationsprojekten."
    imageSrc="/images/solving_complex_things.jpg"
    imageAlt="Forschungs- und Innovationsprojekte"
    imageWidth={2000}
    imageHeight={1368}
  />

  <section class="section pt-0 pb-20">
    <div class="container">
      <div class="mb-10 max-w-4xl border-l-4 border-[#00CE7E] pl-5">
        <p
          class="font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light md:text-[1.125rem]"
        >
          Wir verbinden strategische Forschung mit operativer Umsetzung und
          schaffen damit konkrete Mehrwerte aus Daten, Analytics und KI.
        </p>
      </div>

      {
        researchSections.map((section, index) => (
          <>
            <article class="mb-8 rounded-2xl border border-black/80 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.04)] dark:border-white/70 dark:bg-darkmode-body md:p-8">
              <h2 class="mb-5 font-primary text-h2-sm font-bold text-text-dark dark:text-darkmode-text-dark md:text-h2">
                {section.title}
              </h2>

              {section.paragraphs.map((paragraph) => (
                <p class="mb-4 max-w-5xl font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light md:text-[1.125rem]">
                  {paragraph}
                </p>
              ))}

              {section.lists.map((listItems) => (
                <ul class="mb-5 list-disc space-y-2 pl-5 font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light md:text-[1.125rem]">
                  {listItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ))}
            </article>

            {index < researchSections.length - 1 && (
              <div class="mb-8 h-px w-full bg-black/15 dark:bg-white/20" />
            )}

            {index === 2 && (
              <div class="mb-10 overflow-hidden rounded-2xl border border-black/80 dark:border-white/70">
                <img
                  src="/images/adv_at_work.jpg"
                  alt="Zusammenarbeit in Forschungsprojekten"
                  width="5000"
                  height="3333"
                  loading="lazy"
                  class="h-65 w-full object-cover md:h-90"
                />
              </div>
            )}
          </>
        ))
      }
    </div>
  </section>

  <ContactSpotlightSection
    titleStart="Gemeinsam"
    titleHighlight="Innovationen umsetzen"
    leadText="Wir unterstützen Unternehmen und Projektpartner dabei, innovative Daten- und KI-Lösungen strukturiert aufzubauen. Von der ersten Use-Case-Idee über Architektur und Governance bis hin zu Prototyping und operativer Umsetzung begleiten wir Forschungs- und Innovationsprojekte mit technischem, strategischem und analytischem Fokus."
    followupText="Unser Ziel ist es, Innovation nicht nur theoretisch zu denken, sondern reale Mehrwerte für Unternehmen und Organisationen zu schaffen."
    avatarSrc="/images/andreas.jpg"
    avatarAlt="Andreas"
    buttonHref="https://calendly.com/andreas-klostermann-alpinedata/ersttermin"
    buttonLabel="Erstgespräch vereinbaren"
    imageSrc="/images/kennenlernen.jpg"
    imageAlt="Gemeinsam Innovationen umsetzen"
  />
</Base>
