---
import Base from "@/layouts/Base.astro";
import ProductCatalogApp from "@/layouts/components/catalog/ProductCatalogApp";
import "@/styles/catalog.css";
import config from "@/config/config.json";
import { getProductById, products } from "@/layouts/components/data/useCases";
import {
  buildProductCatalogUrl,
  getCanonicalProductId,
} from "@/layouts/components/data/productCatalogRouting";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { productId: product.id },
    props: {
      initialProductId: product.id,
    },
  }));
}

const { productId } = Astro.params;
const requestedProductId = typeof productId === "string" ? productId : "";
const { initialProductId } = Astro.props as {
  initialProductId: string | null;
};

const canonicalProductId =
  getCanonicalProductId(requestedProductId) ?? initialProductId;

if (!canonicalProductId) {
  return Astro.redirect("/produktkatalog/", 302);
}

const canonicalProduct = getProductById(canonicalProductId);

if (!canonicalProduct) {
  return Astro.redirect("/produktkatalog/", 302);
}

const canonicalUrl = `${config.site.base_url}${buildProductCatalogUrl(canonicalProductId)}`;
const pageTitle = `${canonicalProduct.title} | Produktkatalog – ADV Alpine Data Ventures`;
const pageDescription = canonicalProduct.short;
---

<Base title={pageTitle} description={pageDescription} canonical={canonicalUrl}>
  <section class="adv-catalog">
    <ProductCatalogApp
      client:only="react"
      initialProductId={canonicalProductId}
    >
      <p slot="fallback" class="adv-catalog-loading">
        Produktkatalog wird geladen …
      </p>
    </ProductCatalogApp>
  </section>
</Base>
