---
import SplitInfoSection from "@/components/SplitInfoSection.astro";
import Base from "@/layouts/Base.astro";
import ContactSpotlightSection from "@/partials/ContactSpotlightSection.astro";
import HomepageLeadHeading from "@/partials/HomepageLeadHeading.astro";
import InsightCardsSection from "@/partials/InsightCardsSection.astro";
import TextLeftImageRightSection from "@/partials/TextLeftImageRightSection.astro";

const splitInfoData = {
  enable: true,
  left_intro: 'Sie bekommen nicht "unsere Zeit gegen Geld", sondern',
  left_highlight: "Ergebnisse.",
  left_outro: "",
  left_text:
    "Unser Ansatz ist darauf ausgelegt, Komplexität zu reduzieren und für Sie als Mittelständler maximale Planungssicherheit zu schaffen. Von der ersten Anfrage bis zur fertigen Lösung folgen wir einem klaren Prozess, der Ihre internen Ressourcen schont und schnelle Erfolge liefert.",
  right_title: "Unser Fokus - Ihr Ergebnis",
  items: [
    {
      caption: "Pragmatismus vor Komplexität",
      text: "Sie erhalten Lösungen, die im Alltag funktionieren, statt theoretischer Mammutprojekte.",
    },
    {
      caption: "Volle Kostentransparenz",
      text: "Keine Budgetüberschreitungen durch klare Fixpreis-Modelle und definierte Liefergegenstände.",
    },
    {
      caption: "Nahtlose Integration",
      text: "Wir arbeiten eng mit Ihrer IT und Fachabteilung zusammen, ohne Ihren Betrieb aufzuhalten.",
    },
    {
      caption: "Messbarer Mehrwert",
      text: "Jedes Projekt endet mit einem greifbaren Resultat, das Ihre Entscheidungsgrundlage verbessert.",
    },
  ],
};

const insightCards = [
  {
    icon: "FaBridgeCircleXmark",
    titleHighlight: "Fixpreis",
    titleEnd: " Projekte",
    text: "Planungssicherheit und fertiges Projekt ohne dauernde Budgetausweitung.",
    link: "/fixprice/",
  },
  {
    icon: "LuListX",
    titleStart: "Wie komme ich ",
    titleHighlight: "zum Projekt",
    titleEnd: "?",
    text: "Auf diesem Weg erhalten Sie Ihren nächsten Use Case.",
    link: "/projectstart/",
  },
  {
    icon: "FaAnchorCircleXmark",
    titleHighlight: "Forschung",
    titleEnd: "sprojekte",
    text: "Aus Daten und KI Innovationen für den Mittelstand.",
    link: "/research/",
  },
  {
    icon: "FaSitemap",
    titleStart: "Was unsere ",
    titleHighlight: "Kunden",
    titleEnd: " sagen",
    text: "Hautnah erleben, was unsere Kunden ungeschönt zu sagen haben.",
    link: "/feedback/",
  },
];
---

<Base
  title="So arbeiten wir"
  meta_title="So arbeiten wir"
  description="Klarer Prozess. Gemeinsame Umsetzung. Ergebnisse, die bleiben."
>
  <HomepageLeadHeading
    eyebrow="So arbeiten wir"
    title="Klarer Prozess. Gemeinsame Umsetzung. Ergebnisse, die bleiben."
  />

  <TextLeftImageRightSection
    text="Unser Anspruch ist es, Projekte so schnell, preiswert und qualitativ hochwertig wie möglich umzusetzen und dabei unseren Kunden alles notwendige Know-How zur Weiterentwicklung und Wartung der Systeme mit auf den Weg zu geben. Wir halten nichts von künstlicher Abhängigkeit zu uns, sondern sind überzeugt, dass wir nur dann wachsen können, wenn unser Kunde das ebenso kann. Aus Erfahrung zeigt sich, dass Projekte, welche in kleineren Scheiben Stück für Stück umgesetzt werden, sowie eine gute Change Begleitung genießen, erfolgreicher sind als Großprojekte, die revolutionär eingeführt werden."
    imageSrc="/images/adv_at_work.jpg"
    imageAlt="ADV bei der Arbeit"
    imageWidth={5000}
    imageHeight={3333}
  />
  <SplitInfoSection data={splitInfoData} />

  <InsightCardsSection
    titleStart="So führen wir Sie "
    titleHighlight="ans Ziel"
    cards={insightCards}
  />

  <ContactSpotlightSection
    titleHighlight="Neugierig geworden?"
    leadText="Eine Frage zu uns blieb Ihnen unbeantwortet? Hunger auf ein gemeinsames Projekt? Dann scheuen Sie sich nicht und fragen Sie direkt bei unser Geschäftsführung nach. Andreas nimmt sich gerne Zeit für Sie!"
    avatarSrc="/images/andreas.jpg"
    avatarAlt="Andreas"
    followupText="Buchen Sie einfach einen kurzen Termin für einen ersten Austausch. Wir sortieren Ihre Gedanken, geben eine ehrliche Einschätzung ab und schauen gemeinsam, ob und wie wir Sie unterstützen können."
    buttonHref="https://calendly.com/andreas-klostermann-alpinedata/ersttermin"
    buttonLabel="Termin buchen"
    imageSrc="/images/goat.jpg"
    imageAlt="Neugierig geworden"
  />
</Base>
