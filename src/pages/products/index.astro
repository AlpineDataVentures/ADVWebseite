---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { buildProductCatalogUrl } from "@/layouts/components/data/productCatalogRouting";
import { products } from "@/layouts/components/data/useCases";

const blogTags = (await getTaxonomy("blog", "tags", true)).sort((a, b) =>
  a.localeCompare(b, "de"),
);

const marketingProducts = (await getSinglePage("products"))
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
  }))
  .sort((a, b) => a.title.localeCompare(b.title, "de"));

const catalogProducts = [...products]
  .map((product) => ({
    id: product.id,
    title: product.title,
    url: buildProductCatalogUrl(product.id),
  }))
  .sort((a, b) => a.title.localeCompare(b.title, "de"));
---

<Base
  title="Produktlinks Übersicht | ADV Alpine Data Ventures"
  description="Übersicht aller Marketing-Produktseiten und Produktkatalog-Einträge von ADV – für Navigation und schnellen Zugriff auf Produktinhalte."
>
  <section class="section">
    <div class="container">
      <h1 class="mb-6">Produktlinks Übersicht</h1>
      <p class="mb-10">
        Diese Seite bündelt interne Produkt-URLs für Suchmaschinen-Crawling.
      </p>

      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <h2 class="mb-4">Produktseiten (/products/*)</h2>
          <ul class="space-y-2">
            {
              marketingProducts.map((product) => (
                <li>
                  <a href={`/products/${product.slug}/`}>{product.title}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h2 class="mb-4">Produktkatalog (/produktkatalog/*)</h2>
          <ul class="space-y-2">
            {
              catalogProducts.map((product) => (
                <li>
                  <a href={product.url}>{product.title}</a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-12">
        <h2 class="mb-4">Stichworte aus dem Blog</h2>
        <ul>
          {
            blogTags.map((tag) => (
              <li class="inline-block">
                <a
                  class="m-1 block rounded bg-light px-3 py-1 hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-dark"
                  href={`/tags/${slugify(tag)}/`}
                >
                  {humanize(tag)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Base>
