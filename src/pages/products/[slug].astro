---
import Base from "@/layouts/Base.astro";
import BlogCard from "@/components/BlogCard.astro";
import config from "@/config/config.json";
import ImageMod from "@/components/ImageMod.astro";
import { getEntry, type CollectionEntry } from "astro:content";
import { getSinglePage } from "@/lib/contentParser.astro";
import { FaCheck } from "react-icons/fa";
import {
  buildProductCatalogUrl,
  getCanonicalProductId,
} from "@/layouts/components/data/productCatalogRouting";

export async function getStaticPaths() {
  const products = await getSinglePage("products");

  return products.map((product) => ({
    params: {
      slug: product.id,
    },
    props: { product },
  }));
}

const { product } = Astro.props as { product: CollectionEntry<"products"> };
const {
  title,
  meta_title,
  description,
  eyebrow,
  highlight_text,
  image,
  intro_cta_label,
  benefits,
  contact,
  collaboration_title,
  collaboration_steps,
  delivery,
  related_products,
  tags,
  final_cta_title,
  final_cta_text,
  final_cta_button_label,
  final_cta_image,
} = product.data;

const catalogProductId = getCanonicalProductId(product.id);
const catalogProductUrl = buildProductCatalogUrl(catalogProductId);
const { preview_items } = config.settings;

const allProducts = await getSinglePage("products");
const allPosts = await getSinglePage("blog");
const authorEntry = await getEntry("authors", contact.author_id);

const relatedProductEntries = related_products
  .map((relatedSlug) =>
    allProducts.find((candidate) => candidate.id === relatedSlug),
  )
  .filter((candidate): candidate is CollectionEntry<"products"> =>
    Boolean(candidate),
  );

const normalizedProductTags = new Set(
  tags.map((tag) => tag.toLowerCase().trim()),
);
const relatedPosts = allPosts
  .filter((post) =>
    post.data.tags.some((tag) =>
      normalizedProductTags.has(tag.toLowerCase().trim()),
    ),
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, preview_items);

const highlightValue = highlight_text ?? "";
const highlightIndex = highlightValue
  ? description.indexOf(highlightValue)
  : -1;
const descriptionBefore =
  highlightIndex >= 0 ? description.slice(0, highlightIndex) : description;
const descriptionHighlight = highlightIndex >= 0 ? highlightValue : "";
const descriptionAfter =
  highlightIndex >= 0
    ? description.slice(highlightIndex + highlightValue.length)
    : "";

const advisorName =
  authorEntry?.data.title ??
  authorEntry?.data.blog_name ??
  "Ihr Ansprechpartner";
const advisorRole = authorEntry?.data.role ?? "Consulting";
const advisorImage = authorEntry?.data.image ?? "/images/authors/BenDiez.jpg";
const advisorEmail = authorEntry?.data.email
  ? `mailto:${authorEntry.data.email}`
  : "mailto:info@alpinedata.de";
---

<Base
  title={title}
  meta_title={meta_title ?? title}
  description={description}
  image={image}
>
  <section class="section pt-4">
    <div class="container">
      <div
        class="flex flex-col gap-y-10 lg:flex-row lg:items-stretch lg:gap-y-0"
      >
        <div class="min-w-0 lg:flex-1 lg:pr-10">
          <div class="flex h-full flex-col justify-center text-left">
            <p
              class="mb-3 font-secondary text-lg font-normal text-text-dark dark:text-darkmode-text-light"
            >
              {eyebrow}
            </p>
            <h1
              class="mb-6 font-primary text-h1-sm font-bold text-dark dark:text-darkmode-text-dark md:text-h1 hyphens-auto wrap-break-word"
            >
              {title}
            </h1>
            <p
              class="font-secondary text-lg font-normal text-text dark:text-darkmode-text"
            >
              {descriptionBefore}
              {
                descriptionHighlight && (
                  <span class="adv-contact-gradient font-semibold">
                    {descriptionHighlight}
                  </span>
                )
              }
              {descriptionAfter}
            </p>
            <a
              class="mt-8 inline-flex w-fit items-center justify-center rounded-md bg-[#00CE7E] px-6 py-3 font-secondary text-base font-bold text-white transition-opacity hover:opacity-90"
              href={catalogProductUrl}
            >
              {intro_cta_label}
              <span class="ml-2" aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
        <div class="lg:w-lg lg:shrink-0 lg:pl-10">
          <ImageMod
            src={image}
            width={1200}
            height={900}
            alt={title}
            class="w-full rounded-2xl"
            format="webp"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="flex flex-col gap-y-10 lg:flex-row lg:items-start lg:gap-y-0">
        <div class="min-w-0 lg:flex-1 lg:pr-10">
          <h2
            class="mb-8 font-primary text-h2-sm font-bold text-text-dark dark:text-darkmode-text-dark md:text-h2"
          >
            Ihr <span class="adv-contact-gradient">Mehrwert</span>
          </h2>
          <ul class="space-y-7">
            {
              benefits.map((benefit) => (
                <li class="relative pl-10">
                  <FaCheck className="absolute left-0 top-2 text-[#00A869]" />
                  <h3 class="mb-2 font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark">
                    {benefit.title}
                  </h3>
                  <p class="font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light">
                    {benefit.text}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="lg:w-lg lg:shrink-0 lg:pl-10">
          <div
            class="rounded-2xl border border-border bg-white p-6 dark:border-darkmode-border dark:bg-darkmode-body"
          >
            <h2
              class="mb-5 font-primary text-h3 font-bold text-text-dark dark:text-darkmode-text-dark"
            >
              Ihr Ansprechpartner
            </h2>
            <div
              class="mb-6 rounded-2xl bg-light p-5 text-center dark:bg-darkmode-light"
            >
              <ImageMod
                src={advisorImage}
                width={140}
                height={140}
                alt={advisorName}
                class="mx-auto mb-4 h-28 w-28 rounded-full object-cover"
                format="webp"
              />
              <p
                class="font-primary text-xl font-bold text-text-dark dark:text-darkmode-text-dark"
              >
                {advisorName}
              </p>
              <p
                class="font-secondary text-sm text-text dark:text-darkmode-text-light"
              >
                {advisorRole}
              </p>
            </div>
            <p
              class="mb-6 text-justify font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light"
            >
              {contact.expertise}
            </p>
            <div class="flex flex-col gap-4 sm:flex-row sm:items-stretch">
              <a
                class="btn btn-outline-primary inline-flex w-full items-center justify-center text-center sm:flex-1"
                href={advisorEmail}
              >
                {contact.question_cta_label}
              </a>
              <a
                class="btn btn-primary inline-flex w-full items-center justify-center text-center border border-transparent transition-colors hover:border-black hover:bg-white hover:text-black dark:hover:border-white dark:hover:bg-black dark:hover:text-white sm:flex-1"
                href={contact.meeting_cta_link}
              >
                {contact.meeting_cta_label}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="flex flex-col gap-y-10 lg:flex-row lg:items-start lg:gap-y-0">
        <div class="min-w-0 lg:flex-1 lg:pr-10">
          <h2 class="mb-10 font-primary text-h2-sm font-bold md:text-h2">
            {collaboration_title}
          </h2>
          <ul class="space-y-8">
            {
              collaboration_steps.map((step, index) => (
                <li class="relative grid grid-cols-[2.5rem_1fr] gap-x-5">
                  {index < collaboration_steps.length - 1 && (
                    <span
                      class="absolute left-5 top-12 -bottom-6 w-1 -translate-x-1/2 rounded-full bg-[#00CE7E]"
                      aria-hidden="true"
                    />
                  )}
                  <span class="relative z-10 inline-flex h-10 w-10 items-center justify-center rounded-full border-2 border-[#00CE7E] bg-white font-primary text-lg font-bold text-[#00A869] dark:bg-darkmode-body">
                    {index + 1}
                  </span>
                  <div class="pt-1">
                    <h3 class="font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark">
                      {step.title}
                    </h3>
                    <p class="mt-3 font-secondary text-base leading-relaxed text-text dark:text-darkmode-text-light">
                      {step.text}
                    </p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="lg:w-lg lg:shrink-0 lg:pl-10">
          <div
            class="rounded-2xl border border-border bg-white p-6 dark:border-darkmode-border dark:bg-darkmode-body"
          >
            <div class="grid gap-0">
              <div
                class="grid gap-4 border-b border-border py-5 first:pt-0 dark:border-darkmode-border md:grid-cols-[minmax(0,9rem)_1fr]"
              >
                <h3
                  class="font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark"
                >
                  Instrumente
                </h3>
                <ul
                  class="list-disc space-y-2 pl-5 font-secondary text-base text-text dark:text-darkmode-text-light"
                >
                  {delivery.technologies.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <div
                class="grid gap-4 border-b border-border py-5 dark:border-darkmode-border md:grid-cols-[minmax(0,9rem)_1fr]"
              >
                <h3
                  class="font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark"
                >
                  Ergebnisse
                </h3>
                <ul
                  class="list-disc space-y-2 pl-5 font-secondary text-base text-text dark:text-darkmode-text-light"
                >
                  {delivery.deliverables.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <div class="grid gap-4 pt-5 md:grid-cols-[minmax(0,9rem)_1fr]">
                <h3
                  class="font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark"
                >
                  Betrieb
                </h3>
                <ul
                  class="list-disc space-y-2 pl-5 font-secondary text-base text-text dark:text-darkmode-text-light"
                >
                  {delivery.operations.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    relatedProductEntries.length > 0 && (
      <section class="section pt-0">
        <div class="container">
          <h2 class="mb-10 font-primary text-h2-sm font-bold md:text-h2">
            Verwandte Produkte
          </h2>
          <div class="row">
            {relatedProductEntries.map((relatedProduct) => (
              <div class="mb-6 col-12 lg:col-6">
                <a
                  class="block h-full rounded-2xl border border-border bg-white p-6 transition-colors hover:border-[#00CE7E] dark:border-darkmode-border dark:bg-darkmode-body"
                  href={`/products/${relatedProduct.id}/`}
                >
                  <p class="mb-2 font-secondary text-sm font-semibold uppercase tracking-[0.12em] text-[#00A869]">
                    Produkt
                  </p>
                  <h3 class="mb-3 font-primary text-h5 font-bold text-text-dark dark:text-darkmode-text-dark">
                    {relatedProduct.data.title}
                  </h3>
                  <p class="font-secondary text-base text-text dark:text-darkmode-text-light">
                    {relatedProduct.data.description}
                  </p>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section pt-0">
    <div class="container">
      <div
        class="flex flex-col gap-y-10 lg:flex-row lg:items-stretch lg:gap-y-0"
      >
        <div class="min-w-0 lg:flex-1 lg:pr-10">
          <div class="flex h-full flex-col text-left">
            <h2
              class="mb-4 font-primary text-h2-sm font-bold text-text-dark dark:text-darkmode-text-dark md:text-h2"
            >
              {final_cta_title}
            </h2>
            <p
              class="mb-6 font-secondary text-base leading-relaxed text-text dark:text-darkmode-text md:text-lg"
            >
              {final_cta_text}
            </p>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <a
                class="inline-flex items-center justify-center self-start rounded-md bg-[#00CE7E] px-6 py-3 font-secondary text-base font-bold text-white transition-opacity hover:opacity-90"
                href={catalogProductUrl}
              >
                {final_cta_button_label}
                <span class="ml-2" aria-hidden="true">&rarr;</span>
              </a>
              <a
                class="inline-flex items-center justify-center self-start rounded-md border border-[#00CE7E] px-6 py-3 font-secondary text-base font-bold text-[#00A869] transition-colors hover:bg-[#e8fff5] dark:text-[#7ff2bf] dark:hover:bg-[#0f2a20]"
                href={contact.meeting_cta_link}
              >
                Erstgespräch vereinbaren
              </a>
            </div>
          </div>
        </div>
        <div class="lg:w-lg lg:shrink-0 lg:pl-10">
          <ImageMod
            src={final_cta_image}
            width={1200}
            height={900}
            alt="Produkt-Katalog"
            class="h-full w-full rounded-2xl object-cover"
            format="webp"
          />
        </div>
      </div>
    </div>
  </section>

  {
    relatedPosts.length > 0 && (
      <section class="section pt-0">
        <div class="container">
          <div class="mb-12 border-t-2 border-black pt-10 dark:border-white" />
          <h2 class="mb-12 text-left font-primary text-h2-sm font-bold md:text-h2">
            Zum Thema lesen
          </h2>
          <div class="row justify-center">
            {relatedPosts.map((post) => (
              <div class="mb-10 col-12 lg:col-4">
                <BlogCard data={post} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Base>
