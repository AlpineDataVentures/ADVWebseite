# Normalize line endings for a cross-platform team.
* text=auto eol=lf

# Windows command scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets must never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff2 binary
*.ttf binary
*.pdf binary
*.zip binary
